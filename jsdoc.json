{
    "source": {
        "include": [
            "./src/app/apps/components/messages/",
            "./README.md"
        ],
        "includePattern": "\\.(js|ts)$",
        "exclude": [
            "node_modules/",
            "dist/",
            "**/*.spec.ts",
            "**/*.test.ts"
        ]
    },
    "opts": {
        "destination": "./docs/",
        "recurse": true,
        "readme": "./README.md"
    },
    "plugins": [
        "plugins/markdown"
    ],
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false
    },
    "metadata": {
        "title": "ErrandHelper Frontend Chat System Documentation",
        "description": "Documentation for the Angular-based chat system frontend components and services"
    }
}
